diagrama Flujo;

// Definición de componentes
inicio InicioPrograma;
nodo ValidarUsuario "Verificar credenciales en DB";
nodo AccesoDenegado "Mostrar mensaje error";
nodo AccesoConcedido "Cargar panel principal";
nodo Finalizar "Cerrar sesión";

// Lógica de conexiones
InicioPrograma conecta ValidarUsuario;
ValidarUsuario conecta AccesoDenegado;
ValidarUsuario conecta AccesoConcedido;
AccesoDenegado conecta Finalizar;
AccesoConcedido conecta Finalizar;
